# PropsAI Backend Environment Variables

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_service_role_key

# SportsDataIO
SPORTSDATAIO_API_KEY=your_sportsdataio_api_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Twitter/X API
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Sentry
SENTRY_DSN=your_sentry_dsn

# Notifications
DISCORD_WEBHOOK_URL=

# Trading behavior
PAPER_MODE=true
BANKROLL=250
ENABLE_DYNAMIC_REPRICING=false
MAX_TOTAL_RESTING_ORDERS=50
MAX_RESTING_ORDERS_PER_STRATEGY=15
MAX_ORDER_FAILURES_WINDOW=5
ORDER_FAILURE_WINDOW_MINS=15
REQUIRE_WS_FOR_LIVE=false
AUTO_KILL_ON_ORDER_FAILURES=true
CANCEL_ALERT_WINDOW_MINS=30
CANCEL_ALERT_THRESHOLD=6
AUTO_KILL_ON_CANCEL_STORM=false

# App Settings
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000
